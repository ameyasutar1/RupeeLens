# Copy this file to .env and replace the placeholder locally.
# Never commit your real API key.
GEMINI_API_KEY=replace_with_your_google_ai_studio_key

# Optional but required for persistent uploads on Vercel.
# Create a private Vercel Blob store and copy its read/write token here.
BLOB_READ_WRITE_TOKEN=replace_with_your_vercel_blob_token

# Optional custom key for the private SQLite snapshot.
RUPEELENS_BLOB_DATABASE_PATH=rupeelens/expenses.db

# Optional: creates the first account automatically and migrates the legacy ledger.
RUPEELENS_USERNAME=rupeelens
RUPEELENS_PASSWORD=replace_with_a_long_unique_password

# Required on Vercel if users should be able to create accounts from the login page.
# Share this separately; do not commit the real value.
RUPEELENS_SIGNUP_CODE=replace_with_a_long_random_invitation_code

# Optional locally. On Vercel, prefer RUPEELENS_SIGNUP_CODE.
RUPEELENS_ALLOW_SIGNUP=false

# Prefix for private per-user database snapshots in Vercel Blob.
RUPEELENS_BLOB_PREFIX=rupeelens
